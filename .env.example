# Workspace normally stores provider credentials through Pi's auth flow.
# Environment variables are convenient for local development and CI only.

OPENROUTER_API_KEY=replace-me
# ANTHROPIC_API_KEY=replace-me
# OPENAI_API_KEY=replace-me
# GEMINI_API_KEY=replace-me

# Optional development overrides.
# WORKSPACE_LOCAL_API_PORT=4327
# PI_AGENT_DIR=/absolute/path/to/an/isolated/pi-agent-directory
# WORKSPACE_IMPORT_PYTHON=/absolute/path/to/python
